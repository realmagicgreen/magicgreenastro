{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "coverImage": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "pubDate": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "string"
        }
      ]
    },
    "updatedpubDate": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string",
      "minLength": 11,
      "maxLength": 160
    },
    "ad": {
      "default": false,
      "type": "boolean"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "publish": {
      "default": false,
      "type": "boolean"
    },
    "photography": {
      "default": "unknown",
      "type": "string"
    },
    "canonicalURL": {
      "type": "string",
      "format": "uri"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "coverImage",
    "title",
    "subtitle",
    "category",
    "pubDate",
    "tags",
    "description"
  ]
}