{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "coverImage": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 11,
      "maxLength": 160
    },
    "photography": {
      "default": "unknown",
      "type": "string"
    },
    "canonicalURL": {
      "type": "string",
      "format": "uri"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "coverImage",
    "title",
    "subtitle",
    "description"
  ]
}