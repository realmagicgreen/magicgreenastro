---
import Logo from "@components/Logo.astro";
import FooterMenu from "@components/FooterMenu.astro";
import FooterCopy from "@components/FooterCopy.astro";
import FooterQR from "@components/FooterQR.astro";

export interface Props {
  cssClass: string;
}
const { cssClass } = Astro.props;
---

<style>
  .logo_wrap {
    animation-duration: 1.5s;
    animation-fill-mode: forwards;
  }
  .logo_wrap:hover {
    animation-name: sineSettle;
  }
  .logo_wrap:not(:hover) {
    animation-name: sineSettleReverse;
  }
  @keyframes sineSettle {
    0% {
      transform: rotate(0deg);
    }
    15% {
      transform: rotate(55deg);
    }
    30% {
      transform: rotate(38deg);
    }
    45% {
      transform: rotate(48deg);
    }
    60% {
      transform: rotate(42deg);
    }
    75% {
      transform: rotate(46deg);
    }
    90% {
      transform: rotate(44deg);
    }
    100% {
      transform: rotate(45deg);
    }
  }

  @keyframes sineSettleReverse {
    0% {
      transform: rotate(45deg);
    }
    15% {
      transform: rotate(-10deg);
    }
    30% {
      transform: rotate(7deg);
    }
    45% {
      transform: rotate(-3deg);
    }
    60% {
      transform: rotate(3deg);
    }
    75% {
      transform: rotate(-1deg);
    }
    90% {
      transform: rotate(1deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }
</style>

<footer class={cssClass} role="contentinfo">
  <div class="logo_wrap">
    <Logo />
  </div>

  <div class="container">
    <FooterMenu />
  </div>

  <FooterQR />

  <FooterCopy />
</footer>
